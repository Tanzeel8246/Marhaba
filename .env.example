# ==========================================
# Bake Delight Pro - Production Environment
# ==========================================

# 1. Server Configuration
# ------------------------------------------
# The port where the API server will run
PORT=5000
# The host binding. Use 0.0.0.0 for public access or 127.0.0.0 for localhost only
HOST=0.0.0.0
# The environment type (development, test, production)
NODE_ENV=production

# 2. Database Configuration
# ------------------------------------------
# Connection string to your PostgreSQL database.
# Format: postgres://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgres://postgres:11223344@localhost:5432/postgres

# 3. Security (Optional but Recommended)
# ------------------------------------------
# Secret key for session signing and hashing
SESSION_SECRET=your_super_secret_session_key_here_change_in_production
# Allowed origins for CORS (Useful if frontend and backend are hosted on different domains)
# CORS_ORIGIN=https://www.bursasweets.com

# 4. SSL Configuration (Optional)
# ------------------------------------------
# If you want Node.js to directly handle HTTPS instead of a reverse proxy (like Nginx),
# provide the absolute paths to your SSL certificate files.
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
